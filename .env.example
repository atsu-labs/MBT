# Cloudflare D1 Database ID
# 本番環境用のデータベースIDをここに設定
# wrangler d1 create mbt-db コマンドで作成後、IDをコピー
DATABASE_ID=your_database_id_here

# Basic認証（Cloudflare Workers Secretで設定）
BASIC_AUTH_USERNAME=your_basic_auth_username
BASIC_AUTH_PASSWORD=your_basic_auth_password

# 位置情報共有のパスコード（Cloudflare Workers Secretで設定）
LOCATION_SHARE_PASSCODE=your_location_share_passcode
